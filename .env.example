# ── App URLs ────────────────────────────────────────────────
# Public site origin (used in emails + Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://x7musicgroup.com
CLIENT_URL=https://x7musicgroup.com

# ── Maintenance mode ────────────────────────────────────────
# Set to "on" to serve the maintenance page for the whole site (APIs stay up).
# Leave unset/blank for normal operation.
MAINTENANCE_MODE=

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Email (Namecheap SMTP) ──────────────────────────────────
SMTP_HOST=mail.namecheap.com
SMTP_PORT=465
SMTP_USER=info@x7musicgroup.com
SMTP_PASS=your-mailbox-password

# ── File uploads (Vercel Blob) ──────────────────────────────
# Created automatically when you add Blob storage in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# AI assistant ("Powered by BolivAI") — provider-agnostic over the
# OpenAI-compatible API. Defaults to OpenAI; point LLM_CHAT_BASE_URL at any
# OpenAI-compatible endpoint to self-host.
OPENAI_API_KEY=sk-xxx
# Optional overrides (fall back to OPENAI_API_KEY + OpenAI defaults):
# LLM_CHAT_BASE_URL=https://api.openai.com/v1
# LLM_CHAT_MODEL=gpt-4o-mini
# LLM_CHAT_API_KEY=sk-xxx
# LLM_SEARCH_MODEL=gpt-4o-mini-search-preview   # model X7's web_research tool uses (OpenAI live web search)
# LLM_EMBED_BASE_URL=https://api.openai.com/v1
# LLM_EMBED_MODEL=text-embedding-3-small   # 1536-dim; changing it = re-ingest the brain
# LLM_EMBED_API_KEY=sk-xxx

# Supabase (X7's OWN project — separate from BolivAI). Create at supabase.com,
# then Project Settings → API for these values. See docs/supabase-setup.md.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...   # SERVER-ONLY, bypasses RLS — never expose to the client
